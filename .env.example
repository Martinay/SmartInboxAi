# SmartInboxAI – Umgebungsvariablen
# Kopiere diese Datei als `.env` und trage deine Werte ein.

# OpenAI API Key (für litellm / gpt-4o-mini)
OPENAI_API_KEY=sk-...

# ntfy Server URL (vollständiger Pfad zum Topic)
NTFY_URL=http://ntfy.local/mein_geheimes_topic

# Optionaler ntfy Access-Token (leer lassen wenn Topic ungeschützt)
NTFY_TOKEN=

# Secret Token für Callback-URL-Absicherung (zufälligen String generieren!)
SECRET_TOKEN=mein_super_geheimes_token_abc123

# Basis-URL für ntfy Action-Button Callbacks (NAS-IP + Port)
CALLBACK_BASE_URL=http://192.168.1.100:8000

# Port für den FastAPI Webhook-Server
WEBHOOK_PORT=8000

# Kommaseparierte Liste von Ordnernamen, die ignoriert werden sollen
# Diese Ordner werden beim Kategorien-Scan übersprungen
IGNORE_FOLDERS=Bilder,Weiterbildung
